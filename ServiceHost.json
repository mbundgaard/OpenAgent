{
  "apiPort": 9500,
  "logDirectory": "./logs",
  "services": [
    {
      "name": "openagent",
      "command": "dotnet",
      "args": [
        "run"
      ],
      "workingDirectory": "src/agent/OpenAgent",
      "port": 5264,
      "url": "http://localhost:5264/health",
      "environment": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DATA_DIR": "./data"
      },
      "shutdownTimeoutSeconds": 5
    },
    {
      "name": "openagent-web",
      "command": "cmd",
      "args": [
        "/c",
        "npm",
        "run",
        "dev"
      ],
      "workingDirectory": "src/web",
      "port": 3000,
      "url": "http://localhost:3000",
      "environment": null,
      "shutdownTimeoutSeconds": 5
    }
  ]
}